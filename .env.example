# ============================================================
# LumajiraHub — Variables de entorno
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Completa los valores y reinicia el servidor
# ============================================================

# ------------------------------------------------------------
# OPENAI — Chatbot GPT-4o (OBLIGATORIO para el chatbot)
# https://platform.openai.com/api-keys
# ------------------------------------------------------------
VITE_OPENAI_API_KEY=sk-proj-...

# ------------------------------------------------------------
# FIREBASE — Datos reales persistentes (OBLIGATORIO para producción)
# 1. Ve a https://console.firebase.google.com
# 2. Crea un proyecto
# 3. Habilita Authentication > Email/Password
# 4. Habilita Firestore Database (modo producción o test)
# 5. Ve a Configuración del proyecto > Tus apps > Web > Agregar app
# 6. Copia los valores aquí
# ------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
